# Production secrets template for the MSFG EC2 box.
# Copy to deploy/.env on the server and fill in real values.
# DO NOT commit deploy/.env. It is .gitignored.

# ── AWS RDS Postgres ─────────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.cluster-xxxxx.us-west-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mortgage_app
DB_USERNAME=mortgage_app
DB_PASSWORD=replace-me

# ── AWS S3 (documents bucket — already deployed via CDK) ──────────────────
AWS_REGION=us-west-1
AWS_S3_DOCUMENTS_BUCKET=msfg-mortgage-app-documents-prod

# Either: leave blank and rely on the EC2 instance role (preferred — IAM
# instance profile already grants S3 access), or set explicit creds.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Cognito (Hosted UI user pool) ────────────────────────────────────────
COGNITO_USER_POOL_ID=us-west-1_S6iE2uego
COGNITO_CLIENT_ID=replace-me

# ── App config ───────────────────────────────────────────────────────────
# Frontend origin(s) allowed to call /api. Comma-separated for multiple.
CORS_ALLOWED_ORIGINS=https://app.msfgco.com

# 32-byte base64 key used for any column-level crypto (currently unused;
# generate with: openssl rand -base64 32).
APP_ENCRYPTION_KEY=replace-me
