# React App Environment Variables
REACT_APP_API_URL=http://localhost:8080/api

# Cognito (Phase D — required for sign-in; backend rejects unauthenticated /api requests)
REACT_APP_COGNITO_REGION=us-west-1
REACT_APP_COGNITO_USER_POOL_ID=us-west-1_S6iE2uego
REACT_APP_COGNITO_CLIENT_ID=
REACT_APP_COGNITO_DOMAIN=
# Defaults to {window.origin}/auth/callback if unset
REACT_APP_COGNITO_REDIRECT_URI=
# Defaults to {window.origin} if unset
REACT_APP_COGNITO_POST_LOGOUT_REDIRECT_URI=

# Go High Level Integration (Optional)
REACT_APP_GOHIGHLEVEL_ENABLED=false
