# Copy this file to .env and fill in real values for local dev.
#
# Build tool: Vite. envPrefix is set to ['VITE_', 'REACT_APP_'] in vite.config.js,
# so the existing REACT_APP_* names below are still exposed to the app unchanged
# (read via process.env.REACT_APP_* — Vite bakes them in at build time). New vars
# may use either the REACT_APP_ or VITE_ prefix.

# ── Backend API ────────────────────────────────────────────────────
# Spring Boot runs on 8081 with context-path /api (Phase 1 split)
REACT_APP_API_URL=http://localhost:8081/api

# ── Cognito (shared user pool with the dashboard) ──────────────────
REACT_APP_COGNITO_AUTHORITY=https://cognito-idp.us-west-1.amazonaws.com/us-west-1_S6iE2uego
REACT_APP_COGNITO_CLIENT_ID=34rg0vqoobfv8hhvg8kunkd738
REACT_APP_COGNITO_DOMAIN=https://us-west-1s6ie2uego.auth.us-west-1.amazoncognito.com
REACT_APP_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
REACT_APP_COGNITO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# Passwordless SDK adapter (P3). Region is derived from the authority URL if unset.
# WebAuthn RP-ID defaults to msfgco.com (prod). For LOCAL passkey testing only, set it
# to `localhost` (and use a dev pool whose WebAuthnConfiguration RP-ID is localhost).
# REACT_APP_COGNITO_REGION=us-west-1
# REACT_APP_WEBAUTHN_RP_ID=msfgco.com

# msfg-suite staff console origin (enables the "Open in Suite" staff links)
REACT_APP_SUITE_WEB_URL=https://suite.msfgco.com

# ── Go High Level Integration (Optional) ───────────────────────────
REACT_APP_GOHIGHLEVEL_ENABLED=false
