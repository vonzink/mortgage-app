# Copy this file to .env and fill in real values for local dev.

# ── Backend API ────────────────────────────────────────────────────
# Spring Boot runs on 8081 with context-path /api (Phase 1 split)
REACT_APP_API_URL=http://localhost:8081/api

# ── Cognito (shared user pool with the dashboard) ──────────────────
REACT_APP_COGNITO_AUTHORITY=https://cognito-idp.us-west-1.amazonaws.com/us-west-1_S6iE2uego
REACT_APP_COGNITO_CLIENT_ID=34rg0vqoobfv8hhvg8kunkd738
REACT_APP_COGNITO_DOMAIN=https://us-west-1s6ie2uego.auth.us-west-1.amazoncognito.com
REACT_APP_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
REACT_APP_COGNITO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/

# ── Go High Level Integration (Optional) ───────────────────────────
REACT_APP_GOHIGHLEVEL_ENABLED=false
